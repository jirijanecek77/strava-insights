{$DOMAIN} {
    # Route all /assets/* to frontend
    @assets path /assets/*
    handle @assets {
        reverse_proxy frontend:80
    }

    # Route root and common static files to frontend
    @static_files path / /favicon.ico /robots.txt /manifest.json
    handle @static_files {
        reverse_proxy frontend:80
    }

    # Everything else goes to backend (API routes)
    handle {
        reverse_proxy backend:8000
    }

    encode gzip

    log {
        output stdout
        format json
    }
}
